<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="15.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <Import Project="$(MSBuildExtensionsPath)\$(MSBuildToolsVersion)\Microsoft.Common.props" Condition="Exists('$(MSBuildExtensionsPath)\$(MSBuildToolsVersion)\Microsoft.Common.props')" />
  <Import Project="path.props" />

  <PropertyGroup>
    <Configuration Condition=" '$(Configuration)' == '' ">Debug</Configuration>
    <Platform Condition=" '$(Platform)' == '' ">AnyCPU</Platform>
    <ProjectGuid>{A1B2C3D4-E5F6-7890-ABCD-EF1234567890}</ProjectGuid>
    <OutputType>Exe</OutputType>
    <RootNamespace>BDSM</RootNamespace>
    <AssemblyName>BridgeDnSpyMCP</AssemblyName>
    <TargetFrameworkVersion>v4.8</TargetFrameworkVersion>
    <FileAlignment>512</FileAlignment>
    <AutoGenerateBindingRedirects>true</AutoGenerateBindingRedirects>
    <Deterministic>true</Deterministic>
    <LangVersion>latest</LangVersion>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
  </PropertyGroup>

  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Debug|AnyCPU' ">
    <PlatformTarget>AnyCPU</PlatformTarget>
    <DebugSymbols>true</DebugSymbols>
    <DebugType>full</DebugType>
    <Optimize>false</Optimize>
    <OutputPath>bin\Debug\</OutputPath>
    <DefineConstants>DEBUG;TRACE</DefineConstants>
    <ErrorReport>prompt</ErrorReport>
    <WarningLevel>4</WarningLevel>
    <Prefer32Bit>false</Prefer32Bit>
  </PropertyGroup>

  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Release|AnyCPU' ">
    <PlatformTarget>AnyCPU</PlatformTarget>
    <DebugType>pdbonly</DebugType>
    <Optimize>true</Optimize>
    <OutputPath>bin\Release\</OutputPath>
    <DefineConstants>TRACE</DefineConstants>
    <ErrorReport>prompt</ErrorReport>
    <WarningLevel>4</WarningLevel>
    <Prefer32Bit>false</Prefer32Bit>
  </PropertyGroup>

  <!-- ===== dnSpy 引用（通配符包含 bin 下全部 DLL + exe 入口） ===== -->
  <ItemGroup>
    <Reference Include="System" />
    <Reference Include="System.Core" />
    <Reference Include="System.Xml.Linq" />
    <Reference Include="System.Data.DataSetExtensions" />
    <Reference Include="Microsoft.CSharp" />
    <Reference Include="System.Data" />
    <Reference Include="System.Net.Http" />
    <Reference Include="System.Xml" />

    <!-- Newtonsoft.Json：复制到输出目录 -->
    <None Include="$(DnSpyPath)\bin\Newtonsoft.Json.dll">
      <Link>Newtonsoft.Json.dll</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>


    <Reference Include="$(DnSpyPath)\dnSpy.Console.exe">
      <Private>False</Private>
    </Reference>

    <!-- dnSpy bin\ 下全部 DLL，排除与 .NET Framework 内置程序集重名的 System.* / mscorlib / netstandard -->
    <Reference Include="$(DnSpyPath)\bin\*.dll" Exclude="$(DnSpyPath)\bin\{System.*,mscorlib.dll,netstandard.dll}">
      <Private>False</Private>
    </Reference>
  </ItemGroup>

  <ItemGroup>
    <Compile Include="UserException.cs" />
    <Compile Include="ConfigManager.cs" />
    <Compile Include="DnSpyDependencyResolver.cs" />
    <Compile Include="Models\Models.cs" />
    <Compile Include="Services\DnSpyUtils.cs" />
    <Compile Include="Services\AssemblyLoaderService.cs" />
    <Compile Include="Services\ReferenceFinderService.cs" />
    <Compile Include="Services\MetadataBrowserService.cs" />
    <Compile Include="Services\DecompilationService.cs" />
    <Compile Include="Services\AssemblyEditorService.cs" />
    <Compile Include="Server\Protocol\McpTypes.cs" />
    <Compile Include="Server\McpToolRegistry.cs" />
    <Compile Include="Server\Modules\McpToolRegistry.Setup.cs" />
    <Compile Include="Server\Modules\McpToolRegistry.Assembly.cs" />
    <Compile Include="Server\Modules\McpToolRegistry.References.cs" />
    <Compile Include="Server\Modules\McpToolRegistry.TypeQuery.cs" />
    <Compile Include="Server\Modules\McpToolRegistry.Members.cs" />
    <Compile Include="Server\Modules\McpToolRegistry.MethodDetail.cs" />
    <Compile Include="Server\Modules\McpToolRegistry.Decompilation.cs" />
    <Compile Include="Server\Modules\McpToolRegistry.Editor.cs" />
    <Compile Include="Server\Modules\McpToolRegistry.Server.cs" />
    <Compile Include="Server\McpServer.cs" />
    <Compile Include="Program.cs" />
  </ItemGroup>

  <Import Project="$(MSBuildToolsPath)\Microsoft.CSharp.targets" />
</Project>
